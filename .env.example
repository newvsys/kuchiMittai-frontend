# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env.local for local development
#                Set these in Vercel project settings for production
# ─────────────────────────────────────────────────────────────────────────────

# Backend API root URL (no trailing slash)
# Local:      http://localhost:8080
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL=http://app:8080/api
# ── NextAuth ──────────────────────────────────────────────────────────────────

# Public URL of this Next.js app
# Local:      http://localhost:3000
# Production: https://yourdomain.com  (or your Vercel deployment URL)
NEXTAUTH_URL=http://localhost:3000

# Random secret used to sign/encrypt session tokens — NEVER commit a real value
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
