# ------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL
#   Leave EMPTY in production (Vercel) so the Next.js proxy rewrite is used.
#   The browser calls /api/... on the same Vercel origin -> no CORS.
#   Set to http://localhost:8080 in .env.local for local dev.
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://api.kuchimittai.com/api
# ------------------------------------------------------------
# API_BASE_URL  (server-side only - NOT exposed to the browser)
#   Used by the Next.js rewrite proxy (next.config.mjs) to forward
#   /api/* requests to the real Spring Boot backend.
#
#   Docker Compose (internal network):   http://app:8080/api
#   Vercel production (set in Vercel UI): http://<EC2-PUBLIC-IP>:8080/api
# ------------------------------------------------------------
API_BASE_URL=http://app:8080/api
NODE_ENV=development
DATABASE_URL="postgresql://postgres:onlineshopping@db:5432/onlineshopping?schema=public"
NEXTAUTH_SECRET=12D16C923BA17672F89B18C1DB22A
NEXTAUTH_URL=https://www.kuchimittai.com
